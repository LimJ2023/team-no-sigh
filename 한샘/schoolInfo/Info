//유치원 안내(정보)페이지 정보 내용 부분
//유치원 이름(고정:한샘유치원)
//연락처(schoolTel), 주소(schoolAdd) - main에서 메서드로 입력하기

public class Info {

	public String schoolName = "한샘유치원"; //유치원 이름/고정
	public String schoolTel;
	public String schoolAdd;
	
	
	
	public String getSchoolName() {
		return schoolName;
	}
	
	public String getSchoolTel() {
		return schoolTel;
	}
	public void setSchoolTel(String schoolTel) {
		this.schoolTel = schoolTel;
	}
	public String getSchoolAdd() {
		return schoolAdd;
	}
	public void setSchoolAdd(String schoolAdd) {
		this.schoolAdd = schoolAdd;
	}
	
	
	public void showInfo() { //정보 출력하기
		System.out.println("기관 등록명 : " + schoolName);
		System.out.println("연락처 : " + schoolTel);
		System.out.println("주소 : " + schoolAdd);
	}
	
}
